# ============================================================
# CleanReport — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git
# ============================================================

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/cleanreport
DB_USERNAME=cleanreport
DB_PASSWORD=cleanreport

# --- JWT (generate a secure secret for production) ---
JWT_SECRET=your-secure-secret-key-minimum-256-bits-long-change-this
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# --- Cloudinary (https://cloudinary.com/console) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SendGrid (https://app.sendgrid.com/settings/api_keys) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cleanreport.app
SENDGRID_FROM_NAME=CleanReport

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Server ---
PORT=8080
